# ===========================================
# KOB AI Service 环境变量配置示例
# Phase 4: 2026 年标准
# ===========================================

# -------------------------------------------
# LLM 配置（必需，至少配置一个）
# -------------------------------------------

# Provider 选择: auto | deepseek | openai | glm
# 当同时配置多个 key 时，建议显式设置
AI_PROVIDER=auto

# DeepSeek API（推荐，性价比高）
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# GLM API（智谱 AI，国内可用）
# GLM_API_KEY=your-glm-api-key
# GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4

# OpenAI API（可选）
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_API_BASE=https://api.openai.com/v1

# -------------------------------------------
# Embedding 配置（RAG 必需）
# -------------------------------------------

# DashScope（阿里云，推荐国内使用）
DASHSCOPE_API_KEY=sk-your-dashscope-key
EMBEDDING_MODEL=text-embedding-v3

# -------------------------------------------
# Rerank 配置 (2026 新增)
# -------------------------------------------
# Provider: auto | cohere | siliconflow | llm
# auto: 优先尝试 Cohere/SiliconFlow，失败回退到 LLM
RERANK_PROVIDER=auto

# Cohere Rerank API (推荐，效果最好)
# 注册: https://dashboard.cohere.com/
COHERE_API_KEY=your-cohere-api-key
RERANK_MODEL=rerank-multilingual-v3.0

# SiliconFlow Rerank API (国内备选)
# SILICONFLOW_API_KEY=sk-xxx
# RERANK_MODEL_ALT=BAAI/bge-reranker-v2-m3

# -------------------------------------------
# Vision 配置（多模态图片分析，可选）
# -------------------------------------------

# Vision 模型提供商: auto | openai | dashscope
# auto: 优先 OpenAI GPT-4o，回退 DashScope Qwen-VL
VISION_PROVIDER=auto

# OpenAI GPT-4o（推荐，效果最好）
# 需要配置 OPENAI_API_KEY
# VISION_MODEL=gpt-4o

# DashScope Qwen-VL（国内可用，性价比高）
# 使用 DASHSCOPE_API_KEY
# VISION_MODEL=qwen-vl-max

# -------------------------------------------
# 服务模式
# -------------------------------------------

# mock: 不调用 LLM，返回模拟数据（开发测试用）
# live: 调用真实 LLM
AI_SERVICE_MODE=live

# -------------------------------------------
# 可观测性配置（可选）
# -------------------------------------------

# LangSmith（LangChain 官方，推荐开发调试）
# LANGCHAIN_API_KEY=ls-your-langsmith-key
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=kob-ai-service

# LangFuse（开源替代，推荐生产环境）
# LANGFUSE_PUBLIC_KEY=pk-your-key
# LANGFUSE_SECRET_KEY=sk-your-key
# LANGFUSE_HOST=https://cloud.langfuse.com

# -------------------------------------------
# 数据库配置
# -------------------------------------------

# PostgreSQL（向量数据库）
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=kob
PG_USER=postgres
PG_PASSWORD=your-password

# MySQL（业务数据库）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=kob
MYSQL_USER=root
MYSQL_PASSWORD=your-password

# -------------------------------------------
# 会话存储配置 (2026 新增)
# -------------------------------------------

# 存储类型: memory | redis
# memory: 内存存储，仅限开发环境
# redis: Redis 存储，生产环境推荐
SESSION_STORE=memory

# Redis 配置（当 SESSION_STORE=redis 时必需）
# REDIS_URL=redis://localhost:6379/0

# -------------------------------------------
# 安全配置
# -------------------------------------------

# Rate Limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# -------------------------------------------
# 快速开始
# -------------------------------------------
# 1. 复制此文件: cp .env.example .env
# 2. 填入你的 API Key
# 3. 启动服务: python app.py
# -------------------------------------------
